{UTF-8}
:MACRO: SAMPLE UNTIL(lastTime,input,initval)
SAMPLE UNTIL = INTEG( (1-STEP(1,lastTime))*(input-SAMPLE UNTIL)/TIME STEP$, initval)
	~	input
	~		|

:END OF MACRO:
last time=
	3
	~	Month
	~	hold time: STEP(1,lastTime) is 0 before lastTime, 1 at/after
	|

the input=
	7
	~	dmnl
	~	constant input the sample tracks until last time
	|

initial value=
	2
	~	dmnl
	~	the SAMPLE UNTIL stock's initial value at INITIAL TIME
	|

sampled=
	SAMPLE UNTIL(last time, the input, initial value)
	~	dmnl
	~	invocation of C-LEARN's SAMPLE UNTIL macro (>= 2 args so the call
		is not rewritten to LOOKUP -- GH #553)
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 5
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  =
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

