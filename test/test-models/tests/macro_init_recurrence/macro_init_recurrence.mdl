{UTF-8}
:MACRO: INIT(x)
INIT = INITIAL(x)
	~	passthrough macro
	~	collides with renamed builtin
	|
:END OF MACRO:

Target: (t1-t3)
	~
	~		|

tNext: (t2-t3) -> tPrev
	~
	~		|

tPrev: (t1-t2) -> tNext
	~
	~		|

ecc[t1] = 1 ~~|

ecc[tNext] = INITIAL(ecc[tPrev] * 2) ~~|

FINAL TIME  = 1
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

