{UTF-8}
:MACRO: RAMP FROM TO( xfrom, xto, tstart, tend, islinear)
RAMP FROM TO = IF THEN ELSE( linear,linear ramp,exp ramp)
	~	xfrom
	~	Ramp function with different syntax (specifying from-to rather than slope) \
		and selectable linear or exponential profile.
	|

linear = IF THEN ELSE( xfrom > 0 :AND: xto > 0, islinear, 1)
	~	dmnl
	~	Force linear behavior if endpoints are nonpositive
	|

linear ramp = xfrom + RAMP(slope,tstart,tend)
	~	xfrom
	~		|

exp ramp = IF THEN ELSE(Time$ <= tstart, xfrom
,IF THEN ELSE( Time$ > tend, xto, xfrom*EXP( rate*(Time$-tstart)) ))
	~	xfrom
	~		|

slope = (xto-xfrom)/interval
	~	xfrom/tstart
	~		|

rate = IF THEN ELSE( xfrom > 0 :AND: xto > 0, LN(xto/xfrom)/interval, :NA: )
	~	1/tstart
	~		|

interval = MAX(tend-tstart,TIME STEP$)
	~	tstart
	~		|

:END OF MACRO:
x from=
	2
	~	dmnl
	~	ramp start value (> 0 so the linear/exp branch is selectable)
	|

x to=
	10
	~	dmnl
	~	ramp end value (> 0)
	|

t start=
	1
	~	Month
	~	ramp start time
	|

t end=
	5
	~	Month
	~	ramp end time
	|

is linear=
	1
	~	dmnl
	~	1 => take the linear-ramp branch
	|

ramped=
	RAMP FROM TO(x from, x to, t start, t end, is linear)
	~	dmnl
	~	invocation of C-LEARN's RAMP FROM TO macro, linear branch
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 6
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  =
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

