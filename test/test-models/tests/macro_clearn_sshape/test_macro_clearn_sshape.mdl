{UTF-8}
:MACRO: SSHAPE(xin,profile)
SSHAPE = IF THEN ELSE( input>0.5, 1-(1-input)^profile*0.5/0.5^profile, input^profile*\
		0.5/0.5^profile)
	~	dmnl
	~	S-shaped response, from 0-1 for input from 0-1. Profile should normally be >=1 \
		(1=linear; 2=quadratic)
		Always passes through (0.5, 0.5)
	|

input = MIN(1,MAX(0,xin))
	~	xin
	~		|

:END OF MACRO:
profile=
	2
	~	dmnl
	~	S-curve profile exponent (2 = quadratic)
	|

high input=
	0.8
	~	dmnl
	~	a constant > 0.5 so SSHAPE takes the upper IF branch
	|

low input=
	0.3
	~	dmnl
	~	a constant < 0.5 so SSHAPE takes the lower IF branch
	|

s high=
	SSHAPE(high input, profile)
	~	dmnl
	~	C-LEARN SSHAPE invocation, upper branch (>= 2 args -- not LOOKUP)
	|

s low=
	SSHAPE(low input, profile)
	~	dmnl
	~	C-LEARN SSHAPE invocation, lower branch (>= 2 args -- not LOOKUP)
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  =
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

