{UTF-8}
:MACRO: SCALE(x, k)
SCALE = x * k
	~	dmnl
	~	stockless arrayed macro: scale the input by a factor
	|

:END OF MACRO:
Region: R1, R2, R3
	~	dmnl
	~	a small dimension with one constant per element
	|

inp[Region]=
	10, 20, 30
	~	dmnl
	~	arrayed input, a different constant per element
	|

factor=
	3
	~	dmnl
	~	scalar scale factor (>= 2 args so the call is not LOOKUP -- GH #553)
	|

out[Region]=
	SCALE(inp[Region],factor)
	~	dmnl
	~	apply-to-all macro invocation: one independent macro instance per
		Region element (each computes inp[element] * factor)
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  =
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

