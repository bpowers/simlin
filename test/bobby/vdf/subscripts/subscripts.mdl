{UTF-8}
a stock[sub1]= INTEG (
	net flow[sub1],
		sub1)
	~	
	~		|

net flow[sub1]=
	some rate * a stock[sub1] + other const[sub1]
	~	
	~		|

other const[sub1]=
	0.9,0.3,0.5
	~	
	~		|

some rate=
	0.7
	~	
	~		|

sub1:
	a,b,c
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 23
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

