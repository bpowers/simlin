{UTF-8}
constant=
	3.1415
	~	
	~		|

flow[sub3]=
	v * sub3
	~	
	~		|

stock[sub3]= INTEG (
	flow[sub3],
		2 * sub3)
	~	
	~		|

sub1:
	a,b,c
	~	
	~		|

sub2:
	i,j
	~	
	~		|

sub3:
	x,y
	~	
	~		|

v=
	constant * Time
	~	
	~		~	:SUPPLEMENTARY 
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 17
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 0.5
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Month [0,?]
	~	The time step for the simulation.
	|

