{UTF-8}
inline lookup table=
	WITH LOOKUP(Time, ((0,6),(30,5),(100,3)))
	~	
	~		|

lookup table 1(
	[(0,0)-(100,20)],(0,4),(10,5),(20,6),(30,10),(40,12),(50,13),(60,16),(70,16),(80,18)\
		,(90,19),(100,20))
	~	
	~		|

net change=
	lookup table 1(Time) + inline lookup table
	~	
	~		|

stock= INTEG (
	net change,
		0)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

