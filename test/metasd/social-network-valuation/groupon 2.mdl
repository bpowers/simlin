{UTF-8}
:MACRO: REPORT( flow, reporting interval )
REPORT = INTEG( flow-outflow, flow*reporting interval )
	~	flow*reporting interval
	~		|

outflow = DELAY FIXED(flow,reporting interval,flow)
	~	flow
	~		|

:END OF MACRO:
"$ per k$"==
	1000
	~	$/K$
	~		|

now=
	36
	~	Month
	~		|

Cost of Revenue=
	Revenue*Frac Cost of Revenue
	~	$/Month
	~		|

cost per customer=
	0
	~	$/user/Month [0,1]
	~		|

cost per new subscriber=
	1
	~	$/user [0,10]
	~		|

cost per repeat=
	0
	~	$/user [0,10]
	~		|

cost per subscriber=
	0
	~	$/(user*Month) [0,1]
	~		|

cost per transaction=
	5
	~	$/user [0,10]
	~		|

cost per trial=
	0
	~	$/user [0,10]
	~		|

months per year==
	12
	~	months/year
	~		|

data revenue[Interval]:=
	data revenue k$[Interval]*"$ per k$"
	~	$
	~		|

current interest rate=
	0
	~	fraction/year
	~		|

potential customers=
	fraction ever buying*potential subscribers
	~	users
	~		|

customer saturation effect=
	1-(cumulative customers/potential customers)^customer saturation exponent
	~	Dmnl
	~		|

customer saturation exponent=
	1
	~	Dmnl [0,2]
	~		|

projected dividend payout=
	1
	~	fraction
	~		|

Future Repeat Rate=
	0.2
	~	fraction/Month [0,1]
	~		|

groupon frac err=
	0.1
	~	fraction
	~		|

data groupons sold[Qx3]:=
	GET XLS DATA('?groupon data','users','4','d20') ~~|
data groupons sold[Ann]:=
	GET XLS DATA('?groupon data','users','4','d19')
	~	users
	~		|

dividend PV= INTEG (
	discounted dividend,
		0)
	~	$
	~		|

risk premium=
	0.05
	~	fraction/year
	~		|

"data SG&M cost k$"[Interval]:=
	GET XLS DATA('?groupon data','income','5','r14')
	~	K$
	~		|

"data SG&M cost"[Interval]:=
	"data SG&M cost k$"[Interval]*"$ per k$"
	~	$
	~		|

Reported Oper Profit[Interval]=
	REPORT(Operating Profit,Reporting Period[Interval])
	~	$
	~		|

Discount factor= INTEG (
	-discounting,
		1)
	~	fraction
	~		|

discount rate=
	interest rate+risk premium
	~	fraction/year
	~		|

discounted dividend=
	STEP(1,now)*Discount factor*projected dividend
	~	$/Month
	~		|

discounting=
	STEP(1,now)*Discount factor*discount rate/months per year
	~	fraction/Month
	~		|

Groupon Value=
	dividend PV+terminal value
	~	$
	~		|

groupon weight[Qx3]=
	1/(data groupons sold[Qx3]*groupon frac err*(data groupons sold[Qx3]/reference scale\
		)^err scaling) ~~|
groupon weight[Ann]=
	1/(data groupons sold[Ann]*cust frac err*(data groupons sold[Ann]/reference scale)^err scaling\
		)
	~	1/users
	~		|

"SGA&M Cost"=
	Groupons sold*cost per transaction
	+cumulative customers*cost per customer
	+subscribers*cost per subscriber
	+Adding*cost per new subscriber
	+Trying*cost per trial
	+Total Repeating*cost per repeat
	~	$/Month
	~		|

Frac Cost of Revenue=
	0.15
	~	fraction
	~		|

fraction ever buying=
	0.5
	~	fraction [0,1]
	~		|

interest rate= INTEG (
	interest rate chg,
		current interest rate)
	~	fraction/year
	~		|

subscribers=
	Lurkers+cumulative customers
	~	users
	~		|

interest rate reversion time=
	5
	~	year
	~		|

terminal value=
	discounted dividend*months per year/discount rate
	~	$
	~		|

long run interest rate=
	0.03
	~	fraction/year [-0.1,0.2]
	~		|

Reporting Period[Interval]=
	3,6,9,12
	~	months
	~		|

Trying=
	Lurkers*Fractional Trial Rate*customer saturation effect
	~	users/Month
	~		|

projected dividend=
	Operating Profit*projected dividend payout
	~	$/Month
	~		|

Operating Profit=
	Revenue-Cost of Revenue-"SGA&M Cost"
	~	$/Month
	~		|

interest rate chg=
	(long run interest rate-interest rate)/interest rate reversion time/months per year
	~	fraction/year/Month
	~		|

Reported groupons sold[Interval]=
	REPORT(Groupons sold,Reporting Period[Interval])
	~	users
	~		|

Reported SGAM Cost[Interval]=
	REPORT("SGA&M Cost",Reporting Period[Interval])
	~	$
	~		|

Reported Revenue[Interval]=
	REPORT(Revenue,Reporting Period[Interval])
	~	$
	~		|

Revenue per Use=
	12
	~	$/user [0,20]
	~		|

reference scale=
	1e+006
	~	users
	~		|

cum cust weight=
	1/(data cum cust*cust frac err*(data cum cust/reference scale)^err scaling)
	~	1/users
	~		|

cumulative customers=
	Customers+Repeaters
	~	users
	~		|

repeat cust weight=
	1/(data cum repeat cust*cust frac err*(data cum repeat cust/reference scale)^err scaling\
		)
	~	1/users
	~		|

data cum cust:=
	GET XLS DATA('?groupon data','users','4','d8')
	~	users
	~		|

data cum repeat cust:=
	GET XLS DATA('?groupon data','users','4','d14')
	~	users
	~		|

data revenue k$[Interval]:=
	GET XLS DATA('?groupon data','income','5','r6')
	~	K$
	~		|

Interval:
	Qtr,Half,Qx3,Ann
	~	
	~		|

Groupons sold=
	Trying+Total Repeating
	~	users/Month
	~	Total participation, with first time and repeaters
	|

err scaling=
	-0.5
	~	Dmnl
	~		|

cust frac err=
	0.1
	~	Dmnl
	~		|

subscriber weight=
	1/(data subscribers*cust frac err*(data subscribers/reference scale)^err scaling)
	~	1/users
	~		|

Total Repeating=
	Repeating+Repeaters*Future Repeat Rate
	~	users/Month
	~	Total repeat participation
	|

Revenue=
	Revenue per Use*Groupons sold
	~	$/Month
	~		|

Adding=
	growth rate*effective customers for growth
	~	users/Month
	~		|

relative persuasiveness of lurkers=
	0.5
	~	Dmnl [0,1]
	~		|

effective customers for growth=
	Lurkers*relative persuasiveness of lurkers+Customers+Repeaters
	~	users
	~		|

data subscribers:=
	GET XLS DATA('?groupon data','users','4','d7')
	~	users
	~		|

subscriber saturation effect=
	1-(subscribers/potential subscribers)^subscriber saturation exponent
	~	Dmnl
	~		|

Repeaters= INTEG (
	Repeating,
		0)
	~	users
	~		|

Repeating=
	Customers*Fractional Repeat Rate
	~	users/Month
	~		|

Fractional Repeat Rate=
	0.5
	~	fraction/Month [0,0.2]
	~		|

potential subscribers=
	2e+008
	~	users
	~		|

Customers= INTEG (
	Trying-Repeating,
		0)
	~	users
	~		|

Fractional Trial Rate=
	0.2
	~	fraction/Month [0,0.2]
	~		|

growth rate=
	unsaturated growth rate r*subscriber saturation effect
	~	fraction/Month
	~		|

init users=
	100000
	~	users
	~		|

Lurkers= INTEG (
	Adding-Trying,
		init users)
	~	users
	~		|

subscriber saturation exponent=
	1
	~	Dmnl [0,2]
	~		|

unsaturated growth rate r=
	0.1
	~	fraction/Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 120
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

