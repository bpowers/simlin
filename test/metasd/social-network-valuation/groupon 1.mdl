{UTF-8}
:MACRO: REPORT( flow, reporting interval )
REPORT = INTEG( flow-outflow, flow*reporting interval )
	~	flow*reporting interval
	~		|

outflow = DELAY FIXED(flow,reporting interval,flow)
	~	flow
	~		|

:END OF MACRO:
"$ per k$"==
	1000
	~	$/K$
	~		|

Reporting Period[Interval]=
	3,6,9,12
	~	months
	~		|

Future Repeat Rate=
	0.2
	~	fraction/Month [0,1]
	~		|

data groupons sold[Qx3]:=
	GET XLS DATA('?groupon data','users','4','d20') ~~|
data groupons sold[Ann]:=
	GET XLS DATA('?groupon data','users','4','d19')
	~	users
	~		|

data revenue[Interval]:=
	data revenue k$[Interval]*"$ per k$"
	~	$
	~		|

Reported Revenue[Interval]=
	REPORT(Revenue,Reporting Period[Interval])
	~	$
	~		|

groupon weight[Qx3]=
	1/(data groupons sold[Qx3]*estimated frac err*(data groupons sold[Qx3]/reference scale\
		)^err scaling) ~~|
groupon weight[Ann]=
	1/(data groupons sold[Ann]*estimated frac err*(data groupons sold[Ann]/reference scale\
		)^err scaling)
	~	1/users
	~		|

Reported groupons sold[Interval]=
	REPORT(Groupons sold,Reporting Period[Interval])
	~	users
	~		|

subscribers=
	Lurkers+cumulative customers
	~	users
	~		|

Revenue per Use=
	12
	~	$/user
	~		|

reference scale=
	1e+006
	~	users
	~		|

cum cust weight=
	1/(data cum cust*estimated frac err*(data cum cust/reference scale)^err scaling)
	~	1/users
	~		|

cumulative customers=
	Customers+Repeaters
	~	users
	~		|

repeat cust weight=
	1/(data cum repeat cust*estimated frac err*(data cum repeat cust/reference scale)^err scaling\
		)
	~	1/users
	~		|

data cum cust:=
	GET XLS DATA('?groupon data','users','4','d8')
	~	users
	~		|

data cum repeat cust:=
	GET XLS DATA('?groupon data','users','4','d14')
	~	users
	~		|

data revenue k$[Interval]:=
	GET XLS DATA('?groupon data','income','5','r6')
	~	K$
	~		|

Interval:
	Qtr,Half,Qx3,Ann
	~	
	~		|

Groupons sold=
	Trying+Total Repeating
	~	users/Month
	~	Total participation, with first time and repeaters
	|

err scaling=
	-0.5
	~	Dmnl
	~		|

estimated frac err=
	0.1
	~	Dmnl
	~		|

subscriber weight=
	1/(data subscribers*estimated frac err*(data subscribers/reference scale)^err scaling\
		)
	~	1/users
	~		|

Total Repeating=
	Repeating+Repeaters*Future Repeat Rate
	~	users/Month
	~	Total repeat participation
	|

Revenue=
	Revenue per Use*Groupons sold
	~	$/Month
	~		|

Adding=
	growth rate*effective customers for growth
	~	users/Month
	~		|

relative persuasiveness of lurkers=
	0.5
	~	Dmnl [0,1]
	~		|

effective customers for growth=
	Lurkers*relative persuasiveness of lurkers+Customers+Repeaters
	~	users
	~		|

data subscribers:=
	GET XLS DATA('?groupon data','users','4','d7')
	~	users
	~		|

saturation effect=
	(1-(subscribers/carrying capacity K)^saturation exponent)
	~	Dmnl
	~		|

Repeaters= INTEG (
	Repeating,
		0)
	~	users
	~		|

Repeating=
	Customers*Fractional Repeat Rate
	~	users/Month
	~		|

Fractional Repeat Rate=
	0.5
	~	fraction/Month [0,0.5]
	~		|

carrying capacity K=
	2e+008
	~	users
	~		|

Customers= INTEG (
	Trying-Repeating,
		0)
	~	users
	~		|

Fractional Trial Rate=
	0.2
	~	fraction/Month [0,0.2]
	~		|

growth rate=
	unsaturated growth rate r*saturation effect
	~	fraction/Month
	~		|

init users=
	100000
	~	users
	~		|

Lurkers= INTEG (
	Adding-Trying,
		init users)
	~	users
	~		|

saturation exponent=
	1
	~	Dmnl
	~		|

Trying=
	Lurkers*Fractional Trial Rate
	~	users/Month
	~		|

unsaturated growth rate r=
	0.1
	~	fraction/Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 120
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

