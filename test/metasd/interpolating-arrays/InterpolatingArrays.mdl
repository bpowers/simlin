{UTF-8}
:MACRO: CUBIC SPLINE( t, p0, p1, m0, m1, left extrap, right extrap)
CUBIC SPLINE=IF THEN ELSE( t<0 :AND: left extrap
 , p0+t*m0
 ,IF THEN ELSE( t>=1 :AND: right extrap
   , p1+(t-1)*m1
   , IF THEN ELSE( t>=0 :AND: t<1,spline,0)))
	~	p0
	~		|

spline=
	h00*p0 + h10*m0*t int + h01*p1 + h11*m1*t int
	~	p0
	~		|

h00=
	2*t^3-3*t^2+1
	~	Dmnl
	~		|

h10=
	t^3-2*t^2+t
	~	Dmnl
	~		|

t int = MIN(1,MAX(0,t))
	~	Dmnl
	~		|

h01=
	-2*t^3+3*t^2
	~	Dmnl
	~		|

h11=
	t^3-t^2
	~	Dmnl
	~		|

:END OF MACRO:
spline y=
	SUM(spline segment[i prev!])
	~	dogs
	~		|

extrapolate[i]=
	1,0,0,0,1
	~	Dmnl
	~		|

spline segment[i prev]=
	CUBIC SPLINE(location in interval[i prev],target value[i prev],target value[i next]
	,target slope[i prev],target slope[i next],extrapolate[i prev],extrapolate[i next])
	~	dogs
	~		|

location in interval[i prev]=
	(x-target x[i prev])/(target x[i next]-target x[i prev])
	~	Dmnl
	~		|

i prev:
	(i1-i4) -> i next
	~	
	~		|

i middle:
	(i2-i4)
	~	
	~		|

i next:
	(i2-i5) -> i prev
	~	
	~		|

target slope[i]=
	0,1,0,1,0
	~	dogs
	~		|

Padding=
	0.1
	~	Dmnl [0,0.2]
	~	Amount to extend beyond the 0-1 scaled input range
	|

xmax=
	1
	~	Dmnl
	~		|

type=
	0
	~	Dmnl [0,9,1]
	~	0 a normal lookup function determining y from x.
		
		1 the equivalent of LOOKUP AREA
		
		2 the equivalent of  LOOKUP BACKWARD
		
		3 the equivalent of LOOKUP EXTRAPOLATE
		
		4 the equivalent of LOOKUP FORWARD
		
		5 the equivalent of LOOKUP INVERT
		
		6 the equivalent of LOOKUP SLOPE
		
		7 the equivalent of LOOKUP AREA with extrapolation
		
		8 the equivalent of LOOKUP INVERT with extrapolation
		
		9 the equivalent of LOOKUP SLOPE with extrapolation
	|

VECTOR LOOKUP y=
	VECTOR LOOKUP(target value[i1], x , xmin , xmax , type )
	~	dogs
	~		|

smooth VECTOR LOOKUP y=
	SMOOTH3( VECTOR LOOKUP(target value[i1], x offset , xmin , xmax , type ), smoothing time\
		 )
	~	dogs
	~		|

x offset=
	-Padding + (Time+smoothing time)/(FINAL TIME-INITIAL TIME)*(1+2*Padding)
	~	Dmnl
	~		|

smoothing time=
	8
	~	years [1,20]
	~		|

xmin=
	0
	~	Dmnl
	~		|

i:
	(i1-i5)
	~	
	~		|

j<->
	i
	~	
	~		|

********************************************************
	.Lagrange
********************************************************~
	|

y=
	SUM(target component[i!])
	~	dogs
	~		|

target num[i,j]=
	IF THEN ELSE( i=j, 1, x-target x[j] )
	~	Dmnl
	~		|

target denom[i,j]=
	IF THEN ELSE(i=j, 1, target x[i]-target x[j])
	~	Dmnl
	~		|

target component[i]=
	PROD(target num[i,j!])/PROD(target denom[i,j!])*target value[i]
	~	dogs
	~		|

target x[i]=
	target time[i]/(FINAL TIME-INITIAL TIME)
	~	Dmnl
	~		|

x=
	-Padding + Time/(FINAL TIME-INITIAL TIME)*(1+2*Padding)
	~	Dmnl
	~		|

target time[i]=
	10,30,50,90,100
	~	Year
	~		|

target value[i]=
	2,1,3,5,4
	~	dogs
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Year [0.0625,1]
	~	The time step for the simulation.
	|

