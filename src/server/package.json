{
  "name": "@simlin/server",
  "version": "1.0.0",
  "description": "simlin server backend",
  "repository": "http://github.com/bpowers/simlin",
  "author": "Bobby Powers <bobbypowers@gmail.com>",
  "license": "Apache-2.0",
  "private": true,
  "main": "lib",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@simlin/core": "workspace:*",
    "@simlin/engine": "workspace:*",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.1",
    "google-protobuf": "^4.0.1",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/google-protobuf": "^3.15.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "needs-format": "prettier -l '**/*.ts' '**/*.tsx'",
    "format": "prettier --write '**/*.ts' '**/*.tsx'",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ .",
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf ./lib",
    "build": "tsc -p tsconfig.json",
    "test": "jest",
    "start": "node lib/index.js",
    "start:backend": "export FIRESTORE_EMULATOR_HOST=127.0.0.1:8092; export FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099; export GCLOUD_PROJECT=simlin; pnpm build && exec node lib/index.js"
  }
}
